generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String             @id @default(cuid())
  name                  String?
  email                 String?            @unique
  emailVerified         DateTime?
  image                 String?
  username              String?            @unique
  bio                   String?
  website               String?            @unique
  location              String?
  theme                 String             @default("dark")
  githubProfile         String?
  xProfile              String?
  instagramProfile      String?
  avatarUrl             String?
  cashfreeBeneficiaryId String?
  createdAt             DateTime           @default(now())
  accounts              Account[]
  reposts               Repost[]
  bookmarks             Bookmark[]
  bounties              Bounty[]
  comments              Comment[]
  earnings              CreatorEarning[]
  following             Follow[]           @relation("Following")
  followers             Follow[]           @relation("Followers")
  intelAssets           IntelAsset[]
  likes                 Like[]
  actedNotifications    Notification[]     @relation("Actor")
  receivedNotifications Notification[]     @relation("Receiver")
  payouts               Payout[]
  posts                 Post[]
  prompts               Prompt[]           @relation("CreatedPrompts")
  purchases             Purchase[]
  sessions              Session[]
  signals               Signal[]
  isProfessional        Boolean            @default(false)
  professionalStatus    String             @default("UNCONFIGURED")
  role                  AdminRole          @default(USER)
  bankName              String?
  accountNumber         String?
  ifscCode              String?
  accountHolderName     String?
  expertise             String?
  profileVisits         Int                @default(0)
  isPrivate             Boolean            @default(false)
  gender                String?
  financialAccounts     FinancialAccount[]
  mentionPrivacy        String             @default("EVERYONE") // EVERYONE, FOLLOWERS, NONE
  mentions              Mention[]          @relation("MentionedUser")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE_ADMIN
  VIEW_ONLY
  USER
}

enum AccountType {
  USER
  PLATFORM_ESCROW
  EXTERNAL_CASHFREE
}

enum LedgerGroupType {
  PAYOUT_REQUEST
  PAYOUT_FINALIZED
  REVERSAL
  MIGRATION
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REJECTED
}

model FinancialAccount {
  id        String        @id @default(cuid())
  userId    String?
  type      AccountType   @default(USER)
  balance   Decimal       @default(0) @db.Decimal(18, 2)
  isFrozen  Boolean       @default(false)
  kycStatus String        @default("PENDING")
  entries   LedgerEntry[]
  User      User?         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LedgerGroup {
  id          String          @id @default(cuid())
  type        LedgerGroupType
  status      PayoutStatus? // Nullable, only for payout groups
  transferId  String?         @unique // Locked before API call
  description String?
  entries     LedgerEntry[]
  createdAt   DateTime        @default(now())
}

model LedgerEntry {
  id        String           @id @default(cuid())
  groupId   String
  accountId String
  amount    Decimal          @db.Decimal(18, 2)
  group     LedgerGroup      @relation(fields: [groupId], references: [id])
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([groupId])
}

model Prompt {
  id             String           @id @default(cuid())
  title          String
  description    String?
  previewContent String
  fullContent    String
  content        String?
  category       String?          @default("general")
  aiModel        String?          @default("GPT-4")
  price          Float
  currency       String           @default("INR")
  thumbnailUrl   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  authorId       String
  bookmarks      Bookmark[]
  comments       Comment[]
  earnings       CreatorEarning[]
  likes          Like[]
  notifications  Notification[]
  author         User             @relation("CreatedPrompts", fields: [authorId], references: [id], onDelete: Cascade)
  purchases      Purchase[]
  transactions   Transaction[]
}

model Signal {
  id        String   @id @default(cuid())
  type      String
  origin    String
  priority  String
  strength  String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model Bounty {
  id         String   @id @default(cuid())
  task       String
  reward     String
  difficulty String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model IntelAsset {
  id          String   @id @default(cuid())
  title       String
  price       String
  category    String
  description String
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, promptId])
}

model Transaction {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  promptId  String
  amount    Float
  status    String
  paymentId String?
  createdAt DateTime @default(now())
  Prompt    Prompt   @relation(fields: [promptId], references: [id])
}

model CreatorEarning {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Payout {
  id        String       @id @default(cuid())
  userId    String
  amount    Float
  month     String
  status    PayoutStatus @default(PENDING)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String     @id @default(cuid())
  content   String
  viewCount Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  authorId  String
  bookmarks Bookmark[]
  comments  Comment[]
  likes     Like[]
  reposts   Repost[]
  mentions  Mention[]
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Like {
  id        String   @id @default(cuid())
  type      String   @default("LIKE")
  userId    String
  postId    String?
  promptId  String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt    Prompt?  @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, promptId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String?
  promptId  String?
  parentId  String?
  createdAt DateTime  @default(now())
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt    Prompt?   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  mentions  Mention[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  promptId  String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt    Prompt?  @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, promptId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  userId    String
  actorId   String
  postId    String?
  promptId  String?
  isRead    Boolean  @default(false)
  message   String?
  createdAt DateTime @default(now())
  actor     User     @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
  user      User     @relation("Receiver", fields: [userId], references: [id], onDelete: Cascade)
  Prompt    Prompt?  @relation(fields: [promptId], references: [id])
}

model Mention {
  id        String   @id @default(cuid())
  userId    String // The user being mentioned
  actorId   String // The user who mentioned someone
  postId    String?
  commentId String?
  createdAt DateTime @default(now())
  user      User     @relation("MentionedUser", fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
