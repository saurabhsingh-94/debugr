datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  bio           String?
  website       String?   @unique
  location      String?
  theme         String    @default("dark")

  githubProfile    String?
  xProfile         String?
  instagramProfile String?
  avatarUrl        String?

  cashfreeBeneficiaryId String?
  createdAt             DateTime @default(now())

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  prompts       Prompt[]         @relation("CreatedPrompts")
  purchases     Purchase[]
  earnings      CreatorEarning[]
  payouts       Payout[]
  signals       Signal[]
  bounties      Bounty[]
  intelAssets   IntelAsset[]
  receivedNotifications Notification[] @relation("Receiver")
  actedNotifications    Notification[] @relation("Actor")

  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]

  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")
}

model Prompt {
  id             String   @id @default(cuid())
  title          String
  description    String?  @db.Text
  previewContent String   @db.Text
  fullContent    String   @db.Text
  content        String?  @db.Text
  category       String?  @default("general")
  aiModel        String?  @default("GPT-4")
  price          Float
  currency       String   @default("INR")
  thumbnailUrl   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorId String
  author   User             @relation("CreatedPrompts", fields: [authorId], references: [id])
  purchases Purchase[]
  earnings  CreatorEarning[]

  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]
}

model Signal {
  id        String   @id @default(cuid())
  type      String
  origin    String
  priority  String
  strength  String
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model Bounty {
  id         String   @id @default(cuid())
  task       String
  reward     String
  difficulty String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model IntelAsset {
  id          String   @id @default(cuid())
  title       String
  price       String
  category    String
  description String   @db.Text
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  prompt Prompt @relation(fields: [promptId], references: [id])

  @@unique([userId, promptId])
}

model Transaction {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  promptId  String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model CreatorEarning {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  prompt Prompt @relation(fields: [promptId], references: [id])
}

model Payout {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  month     String
  status    String   @default("PROCESSING")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  promptId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, promptId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  postId    String?
  promptId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  promptId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, promptId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  userId    String
  actorId   String
  postId    String?
  promptId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("Receiver", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
